# Convex — from dashboard (Settings → URL & Deploy Key)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.eu-west-1.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment
CONVEX_URL=https://your-deployment.eu-west-1.convex.cloud
# HTTP actions base URL (shown beside Cloud URL in dashboard)
CONVEX_SITE_URL=https://your-deployment.eu-west-1.convex.site

# --- Set on Convex deployment via `npx convex env set` (not in .env.local) ---

# Auth redirects (local dev)
# SITE_URL=http://localhost:3000

# Dev-only staff password reset (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))")
# DEV_AUTH_RESET_SECRET=

# AI — required for real classify/scan; without it demo scan still runs
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENAI_FALLBACK=1
