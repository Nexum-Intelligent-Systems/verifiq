{
  "name": "verifiq",
  "version": "0.3.0-phase1",
  "private": true,
  "description": "VerifIQ — Irish pre-build compliance review platform. Phase 1: schema + LLM adapter + R2 storage adapter.",
  "type": "module",
  "scripts": {
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:codegen": "convex codegen",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "convex": "^1.16.0",
    "openai": "^4.67.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^4.0.4",
    "@eslint/js": "^9.12.0",
    "@types/node": "^20.16.0",
    "convex-test": "^0.0.35",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
