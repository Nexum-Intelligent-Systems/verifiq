{
  "name": "verifiq",
  "version": "0.7.0-phase5",
  "private": true,
  "description": "VerifIQ — Irish pre-build compliance review platform. Phase 5: prompt bundling + the runReview node action + scheduled resume tick (council runs on Convex), plus the PR-7 security/correctness hardening.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen:stub": "node scripts/gen-convex-stub.mjs",
    "bundle:prompts": "node scripts/bundle-prompts.mjs",
    "check:hygiene": "node scripts/check-hygiene.mjs",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "app:dev": "next dev",
    "app:build": "next build",
    "app:start": "next start",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "@aws-sdk/client-s3": "3.726.1",
    "@aws-sdk/s3-request-presigner": "3.726.1",
    "@napi-rs/canvas": "0.1.84",
    "convex": "1.17.4",
    "fflate": "^0.8.2",
    "next": "14.2.21",
    "openai": "4.77.3",
    "pdfjs-dist": "6.0.227",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@edge-runtime/vm": "4.0.4",
    "@types/node": "20.17.10",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "convex-test": "0.0.37",
    "eslint": "8.57.1",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
