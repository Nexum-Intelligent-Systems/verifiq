{
  "name": "verifiq",
  "version": "0.3.0-phase1",
  "private": true,
  "description": "VerifIQ — Irish pre-build compliance review platform. Phase 1: schema + LLM adapter + R2 storage adapter.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "@aws-sdk/client-s3": "3.726.1",
    "@aws-sdk/s3-request-presigner": "3.726.1",
    "convex": "1.17.4",
    "openai": "4.77.3"
  },
  "devDependencies": {
    "@edge-runtime/vm": "4.0.4",
    "@types/node": "20.17.10",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "convex-test": "0.0.37",
    "eslint": "8.57.1",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
