# VerifIQ — Phase 1 environment template.
# Copy to .env.local and fill in. NEVER commit .env.local (see .gitignore).

# ── AI providers ──────────────────────────────────────────────────────────
# Primary review/classification/chair/adjudication provider.
ANTHROPIC_API_KEY=
# Fallback + peer-challenge provider.
OPENAI_API_KEY=

# ── Convex (filled by `npx convex dev` on first run) ────────────────────────
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ── Cloudflare R2 (S3-compatible object storage, EU jurisdiction) ───────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=verifiq-prod-eu-west
# Public base URL for the bucket (r2.dev subdomain or custom domain).
R2_PUBLIC_URL=https://verifiq-prod-eu-west.r2.dev

# ── Storage routing ─────────────────────────────────────────────────────────
# Files at or above this size (bytes) route to R2; smaller may use Convex.
# Default 100 MB per docs/27 stack decision.
STORAGE_R2_THRESHOLD_BYTES=104857600

# ── Auth: Convex Auth (docs/42 D1 — replaces Clerk) ─────────────────────────
# Set by `npx @convex-dev/auth` on first run (signing keys + site URL).
SITE_URL=http://localhost:3000
JWT_PRIVATE_KEY=
JWKS=

# ── Magic-code intake + direct upload (docs/42) ─────────────────────────────
# Server-side pepper for hashing upload codes — REQUIRED in any deployment.
# Generate a long random value; never reuse across environments.
UPLOAD_TOKEN_PEPPER=
# Base URL the emailed upload link points at (docs/42 D3).
APP_BASE_URL=https://app.verifiq.ie
# CORS origin allowed to POST the website intake (default * for local dev).
INTAKE_ALLOWED_ORIGIN=https://verifiq.ie

# ── Transactional email: Resend ─────────────────────────────────────────────
# EU-resident recipients: authenticate the sending domain in Resend's EU region
# (eu-west-1, Ireland) and use a key + EMAIL_FROM on that domain. Region is a
# per-domain setting, not a request param — see docs/43 §1a (and its residency
# caveat: Resend stores metadata/logs in the US regardless of region).
RESEND_API_KEY=
EMAIL_FROM=VerifIQ <hello@verifiq.ie>
