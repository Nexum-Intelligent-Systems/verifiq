# VerifIQ — Phase 1 environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.

# ---------------------------------------------------------------------------
# AI providers
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Convex (populated by `npx convex dev` on first run)
# ---------------------------------------------------------------------------
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ---------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible, EU jurisdiction) — see docs/27
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=verifiq-prod-eu-west
R2_PUBLIC_URL=https://verifiq-prod-eu-west.r2.dev

# ---------------------------------------------------------------------------
# Storage routing threshold (bytes). Files at/above this go to R2; below
# go to Convex-native storage. Default 100 MB per docs/27 decision.
# ---------------------------------------------------------------------------
STORAGE_R2_THRESHOLD_BYTES=104857600

# ---------------------------------------------------------------------------
# Clerk (auth — Phase 2 wiring; stub auth used in Phase 1)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
